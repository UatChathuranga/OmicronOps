{
  "name": "omicron-ops",
  "private": true,
  "version": "1.0.3",
  "description": "OmicronOps - A modern DevOps and remote management client",
  "homepage": "https://github.com/UatChathuranga/OmicronOps",
  "author": {
    "name": "Chathuranga",
    "email": "uatchathuranga@gmail.com"
  },
  "type": "module",
  "main": "electron.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/server.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node server/server.js",
    "setup": "npm install",
    "app": "electron . --no-sandbox",
    "dist": "electron-builder"
  },
  "build": {
    "npmRebuild": false,
    "appId": "com.omicronops.app",
    "productName": "OmicronOps",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "server/**/*",
      "electron.js",
      "package.json"
    ],
    "linux": {
      "target": [
        "deb",
        "rpm"
      ],
      "category": "Utility"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ssh2": "^1.16.0",
    "ws": "^8.17.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.3",
    "vite": "^5.3.1"
  }
}